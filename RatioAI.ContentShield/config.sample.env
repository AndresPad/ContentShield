# ContentShield sample configuration
# Copy this file to .env for local development, then replace placeholders.
# Do not commit .env or real secrets.

# Azure Content Safety Prompt Shield. Leave CONTENT_SAFETY_KEY blank to use DefaultAzureCredential.
CONTENT_SAFETY_ENDPOINT=https://<content-safety-resource>.cognitiveservices.azure.com
CONTENT_SAFETY_API_VERSION=2024-09-01
CONTENT_SAFETY_TIMEOUT_SECONDS=15
# CONTENT_SAFETY_KEY=

# Stage1 AOAI embeddings. Leave STAGE1_AOAI_KEY blank to use DefaultAzureCredential.
STAGE1_AOAI_ENDPOINT=https://<azure-openai-resource>.openai.azure.com
STAGE1_AOAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
STAGE1_AOAI_API_VERSION=2024-02-01
STAGE1_AOAI_TIMEOUT_SECONDS=15
# STAGE1_AOAI_KEY=

# Stage1 classifier tunables. Usually leave unset unless recalibrating.
# STAGE1_DECISION_THRESHOLD=
STAGE1_EARLY_STOP_THRESHOLD=0.90

# Stage2 service. For the RATIO dev deployment, use:
# SLM_ENDPOINT=https://ca-contentshield-stage2.blackhill-c3044540.westus3.azurecontainerapps.io
SLM_ENDPOINT=https://<stage2-container-app-fqdn>
SLM_PATH=/classify
SLM_TIMEOUT_SECONDS=15
SLM_MODEL=google/gemma-4-31b-it

# Stage2 image/runtime settings. HF_TOKEN is required only when building/running Stage2.
MODEL_NAME=google/gemma-4-31b-it
MAX_MODEL_LEN=20000
GPU_MEMORY_UTILIZATION=0.9
LANGUAGE_MODEL_ONLY=true
ENABLE_THINKING=false
EXTRA_ENGINE_ARGS=--enable-prefix-caching
ENABLE_STAGE2_REASON=false
MAX_REASON_TOKENS=64
# CLASSIFIER_PROMPT_TEXT=
# REASON_PROMPT_TEXT=
HF_HOME=/mnt/hfcache
# HF_TOKEN=<hugging-face-token-with-gemma-access>
