# syntax=docker/dockerfile:1
# CPU Stage2 image. The wrapper preserves the /health and /classify contract
# while delegating classification to GPT-4o hosted on Azure OpenAI.
FROM mcr.microsoft.com/mirror/docker/library/python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    UV_COMPILE_BYTECODE=1 \
    UV_LINK_MODE=copy

WORKDIR /app

RUN pip install --no-cache-dir uv==0.8.15

COPY pyproject.toml uv.lock ./
RUN uv sync --frozen --no-dev --no-install-project

COPY src/stage2 ./src/stage2
COPY prompts/pi-classifier-gpt4o-v1.txt ./prompts/pi-classifier-gpt4o-v1.txt
COPY prompts/pi-reason-v1.txt ./prompts/pi-reason-v1.txt

ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONPATH=/app/src \
    STAGE2_BACKEND=azure_openai \
    PROMPT_PATH=/app/prompts/pi-classifier-gpt4o-v1.txt \
    REASON_PROMPT_PATH=/app/prompts/pi-reason-v1.txt \
    ENABLE_STAGE2_REASON=false \
    AZURE_OPENAI_DEPLOYMENT=gpt-4o \
    AZURE_OPENAI_API_VERSION=2024-10-21 \
    AZURE_OPENAI_TOP_LOGPROBS=10 \
    AZURE_OPENAI_MAX_RETRIES=1 \
    AZURE_OPENAI_TIMEOUT_S=3

RUN groupadd --gid 1000 app \
    && useradd --uid 1000 --gid 1000 --create-home app \
    && chown -R app:app /app

USER app

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/health', timeout=3)" || exit 1

CMD ["uvicorn", "stage2.main:app", "--host", "0.0.0.0", "--port", "8080", "--log-level", "info"]
