# Gemma 4 31B-it - 31B dense, multimodal (language-only mode)
MODEL_NAME=google/gemma-4-31b-it
APP_NAME=ca-contentshield-stage2
BASE_IMAGE=ratioaidev.azurecr.io/contentshield-stage2:v1
IMAGE=ratioaidev.azurecr.io/contentshield-stage2:v2
ENGINE=vllm
WORKLOAD_PROFILE=GPUNC24A100
CPU=6
MEMORY=12Gi
TARGET_PORT=8080
INGRESS=external
MIN_REPLICAS=1
MAX_REPLICAS=1
REGISTRY_SERVER=ratioaidev.azurecr.io
REGISTRY_IDENTITY=system-environment
HF_HOME=/mnt/hfcache

MAX_MODEL_LEN=20000
GPU_MEMORY_UTILIZATION=0.9
LANGUAGE_MODEL_ONLY=true
ENABLE_THINKING=true
REQUIRES_HF_TOKEN=true
EXTRA_ENGINE_ARGS="--reasoning-parser gemma4 --enable-prefix-caching"
